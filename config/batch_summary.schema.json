{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "batch_summary.schema.json",
  "title": "Batch Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary_schema_version",
    "summary_schema_ref",
    "summary_changelog_ref",
    "summary_contract",
    "batch_time",
    "total_archives",
    "total_pages",
    "success_count",
    "fail_count",
    "failure_breakdown",
    "results"
  ],
  "properties": {
    "summary_schema_version": {
      "type": "string",
      "pattern": "^1\\.\\d+\\.\\d+$"
    },
    "summary_schema_ref": {
      "type": "string",
      "const": "config/batch_summary.schema.json"
    },
    "summary_changelog_ref": {
      "type": "string",
      "const": "config/batch_summary.schema.changelog.md"
    },
    "summary_contract": {
      "$ref": "#/$defs/summary_contract"
    },
    "batch_time": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T"
    },
    "total_archives": {
      "type": "integer",
      "minimum": 0
    },
    "total_pages": {
      "type": "integer",
      "minimum": 0
    },
    "success_count": {
      "type": "integer",
      "minimum": 0
    },
    "fail_count": {
      "type": "integer",
      "minimum": 0
    },
    "failure_breakdown": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/result"
      }
    }
  },
  "$defs": {
    "summary_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary_fields",
        "result_required_fields",
        "result_field_descriptions",
        "status_values",
        "error_codes",
        "schema_version_policy"
      ],
      "properties": {
        "summary_fields": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "required": [
            "summary_schema_version",
            "summary_schema_ref",
            "summary_changelog_ref",
            "batch_time",
            "total_archives",
            "total_pages",
            "success_count",
            "fail_count",
            "failure_breakdown",
            "results"
          ]
        },
        "result_required_fields": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "result_field_descriptions": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "required": [
            "archive_name",
            "status",
            "metadata",
            "error_code",
            "error_message",
            "error",
            "source_folder",
            "page_count",
            "image_files",
            "image_names",
            "processed_time"
          ]
        },
        "status_values": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "success",
              "failed",
              "error"
            ]
          }
        },
        "error_codes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "NO_IMAGES",
              "EMPTY_METADATA",
              "PROCESS_EXCEPTION",
              "UNKNOWN_ERROR"
            ]
          }
        },
        "schema_version_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "scheme",
            "compatibility_rule",
            "minor_rule",
            "patch_rule"
          ],
          "properties": {
            "scheme": {
              "type": "string",
              "const": "semver"
            },
            "compatibility_rule": {
              "type": "string"
            },
            "minor_rule": {
              "type": "string"
            },
            "patch_rule": {
              "type": "string"
            }
          }
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "archive_name",
        "source_folder",
        "page_count",
        "image_files",
        "image_names",
        "processed_time",
        "metadata",
        "status",
        "error_code",
        "error_message",
        "error"
      ],
      "properties": {
        "archive_name": {
          "type": "string"
        },
        "source_folder": {
          "type": [
            "string",
            "null"
          ]
        },
        "page_count": {
          "type": "integer",
          "minimum": 0
        },
        "image_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "image_names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "processed_time": {
          "type": [
            "string",
            "null"
          ]
        },
        "metadata": {
          "type": [
            "object",
            "null"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "success",
            "failed",
            "error"
          ]
        },
        "error_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "error_message": {
          "type": [
            "string",
            "null"
          ]
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        },
        "traceback": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "success"
              }
            }
          },
          "then": {
            "properties": {
              "metadata": {
                "type": "object"
              },
              "error_code": {
                "type": "null"
              },
              "error_message": {
                "type": "null"
              },
              "error": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "failed"
              }
            }
          },
          "then": {
            "properties": {
              "metadata": {
                "type": "null"
              },
              "error_code": {
                "type": "string"
              },
              "error_message": {
                "type": "string"
              },
              "error": {
                "type": "string"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "error"
              }
            }
          },
          "then": {
            "required": [
              "traceback"
            ],
            "properties": {
              "metadata": {
                "type": "null"
              },
              "error_code": {
                "type": "string"
              },
              "error_message": {
                "type": "string"
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      ]
    }
  }
}
